{
  "name": "@sirel/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./const": {
      "types": "./dist/const.d.ts",
      "import": "./dist/const.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./schemas/processos": {
      "types": "./dist/schemas/processos.d.ts",
      "import": "./dist/schemas/processos.js"
    },
    "./schemas/dashboard": {
      "types": "./dist/schemas/dashboard.d.ts",
      "import": "./dist/schemas/dashboard.js"
    },
    "./schemas/planejamento": {
      "types": "./dist/schemas/planejamento.d.ts",
      "import": "./dist/schemas/planejamento.js"
    },
    "./schemas/workflow": {
      "types": "./dist/schemas/workflow.d.ts",
      "import": "./dist/schemas/workflow.js"
    },
    "./schemas/usuarios": {
      "types": "./dist/schemas/usuarios.d.ts",
      "import": "./dist/schemas/usuarios.js"
    },
    "./document-templates/planejamento": {
      "types": "./dist/document-templates/planejamento.d.ts",
      "import": "./dist/document-templates/planejamento.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.2"
  }
}
